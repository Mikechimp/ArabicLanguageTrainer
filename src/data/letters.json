[
  { "name":"Alif", "ar":"ا", "sound":"a / ā", "isolated":"ا", "initial":"ا", "medial":"ـا", "final":"ـا", "type":"vowel carrier", "tip":"Like 'a' in 'father'. It's a tall vertical stroke and the first letter. It doesn't connect to the left.", "examples":[{"ar":"أب","en":"father","tr":"ab"},{"ar":"أمّ","en":"mother","tr":"umm"}] },
  { "name":"Ba", "ar":"ب", "sound":"b", "isolated":"ب", "initial":"بـ", "medial":"ـبـ", "final":"ـب", "type":"sun letter", "tip":"Like English 'b'. Has ONE dot below. Compare with ت (two dots above) and ث (three dots above).", "examples":[{"ar":"باب","en":"door","tr":"bāb"},{"ar":"بيت","en":"house","tr":"bayt"}] },
  { "name":"Ta", "ar":"ت", "sound":"t", "isolated":"ت", "initial":"تـ", "medial":"ـتـ", "final":"ـت", "type":"sun letter", "tip":"Like English 't'. Has TWO dots above. Same base shape as ب.", "examples":[{"ar":"تمر","en":"dates (fruit)","tr":"tamr"},{"ar":"تين","en":"figs","tr":"tīn"}] },
  { "name":"Tha", "ar":"ث", "sound":"th (think)", "isolated":"ث", "initial":"ثـ", "medial":"ـثـ", "final":"ـث", "type":"sun letter", "tip":"Like 'th' in 'think'. THREE dots above. Same base shape as ب and ت.", "examples":[{"ar":"ثلج","en":"snow/ice","tr":"thalj"},{"ar":"ثوب","en":"garment","tr":"thawb"}] },
  { "name":"Jim", "ar":"ج", "sound":"j", "isolated":"ج", "initial":"جـ", "medial":"ـجـ", "final":"ـج", "type":"moon letter", "tip":"Like 'j' in 'jump'. Has a deep bowl shape with one dot inside.", "examples":[{"ar":"جمل","en":"camel","tr":"jamal"},{"ar":"جبل","en":"mountain","tr":"jabal"}] },
  { "name":"Ha", "ar":"ح", "sound":"ḥ (deep h)", "isolated":"ح", "initial":"حـ", "medial":"ـحـ", "final":"ـح", "type":"moon letter", "tip":"A deep, breathy 'h' from the throat — NOT like English 'h'. Same shape as ج but NO dot.", "examples":[{"ar":"حب","en":"love","tr":"ḥubb"},{"ar":"حليب","en":"milk","tr":"ḥalīb"}] },
  { "name":"Kha", "ar":"خ", "sound":"kh (Scottish loch)", "isolated":"خ", "initial":"خـ", "medial":"ـخـ", "final":"ـخ", "type":"moon letter", "tip":"Like 'ch' in Scottish 'loch'. Same shape as ح but with a dot above.", "examples":[{"ar":"خبز","en":"bread","tr":"khubz"},{"ar":"خير","en":"good/goodness","tr":"khayr"}] },
  { "name":"Dal", "ar":"د", "sound":"d", "isolated":"د", "initial":"د", "medial":"ـد", "final":"ـد", "type":"sun letter", "tip":"Like English 'd'. Does NOT connect to the left. A small angular hook shape.", "examples":[{"ar":"دار","en":"house","tr":"dār"},{"ar":"دم","en":"blood","tr":"dam"}] },
  { "name":"Dhal", "ar":"ذ", "sound":"dh (this)", "isolated":"ذ", "initial":"ذ", "medial":"ـذ", "final":"ـذ", "type":"sun letter", "tip":"Like 'th' in 'this' (voiced). Same shape as د but with a dot above.", "examples":[{"ar":"ذهب","en":"gold","tr":"dhahab"},{"ar":"ذئب","en":"wolf","tr":"dhi'b"}] },
  { "name":"Ra", "ar":"ر", "sound":"r (rolled)", "isolated":"ر", "initial":"ر", "medial":"ـر", "final":"ـر", "type":"sun letter", "tip":"A rolled/trilled 'r'. Looks like a small hook dipping below the line. Does not connect left.", "examples":[{"ar":"رجل","en":"man","tr":"rajul"},{"ar":"رأس","en":"head","tr":"ra's"}] },
  { "name":"Zay", "ar":"ز", "sound":"z", "isolated":"ز", "initial":"ز", "medial":"ـز", "final":"ـز", "type":"sun letter", "tip":"Like English 'z'. Same shape as ر but with a dot above.", "examples":[{"ar":"زيت","en":"oil","tr":"zayt"},{"ar":"زهر","en":"flower","tr":"zahr"}] },
  { "name":"Sin", "ar":"س", "sound":"s", "isolated":"س", "initial":"سـ", "medial":"ـسـ", "final":"ـس", "type":"sun letter", "tip":"Like English 's'. Has a flowing shape with three teeth/peaks.", "examples":[{"ar":"سلام","en":"peace","tr":"salām"},{"ar":"سمك","en":"fish","tr":"samak"}] },
  { "name":"Shin", "ar":"ش", "sound":"sh", "isolated":"ش", "initial":"شـ", "medial":"ـشـ", "final":"ـش", "type":"sun letter", "tip":"Like 'sh' in 'ship'. Same as س but with three dots above.", "examples":[{"ar":"شمس","en":"sun","tr":"shams"},{"ar":"شاي","en":"tea","tr":"shāy"}] },
  { "name":"Sad", "ar":"ص", "sound":"ṣ (emphatic s)", "isolated":"ص", "initial":"صـ", "medial":"ـصـ", "final":"ـص", "type":"sun letter", "tip":"An emphatic 's' — tongue pressed against upper palate. Rounder/bigger than س.", "examples":[{"ar":"صبر","en":"patience","tr":"ṣabr"},{"ar":"صديق","en":"friend","tr":"ṣadīq"}] },
  { "name":"Dad", "ar":"ض", "sound":"ḍ (emphatic d)", "isolated":"ض", "initial":"ضـ", "medial":"ـضـ", "final":"ـض", "type":"sun letter", "tip":"An emphatic 'd'. Same shape as ص with a dot above. Arabic is called 'the language of Ḍād'.", "examples":[{"ar":"ضوء","en":"light","tr":"ḍaw'"},{"ar":"أرض","en":"earth/land","tr":"arḍ"}] },
  { "name":"Taa", "ar":"ط", "sound":"ṭ (emphatic t)", "isolated":"ط", "initial":"طـ", "medial":"ـطـ", "final":"ـط", "type":"sun letter", "tip":"An emphatic 't'. A tall loop that stands upright.", "examples":[{"ar":"طعام","en":"food","tr":"ṭa'ām"},{"ar":"طفل","en":"child","tr":"ṭifl"}] },
  { "name":"Dhaa", "ar":"ظ", "sound":"ẓ (emphatic dh)", "isolated":"ظ", "initial":"ظـ", "medial":"ـظـ", "final":"ـظ", "type":"sun letter", "tip":"An emphatic 'dh'. Same shape as ط but with a dot above.", "examples":[{"ar":"ظهر","en":"noon/back","tr":"ẓuhr"},{"ar":"ظل","en":"shadow","tr":"ẓill"}] },
  { "name":"Ain", "ar":"ع", "sound":"ʿ (deep throat)", "isolated":"ع", "initial":"عـ", "medial":"ـعـ", "final":"ـع", "type":"moon letter", "tip":"A deep guttural sound from the throat — unique to Arabic! No English equivalent. Like squeezing the throat.", "examples":[{"ar":"عين","en":"eye","tr":"'ayn"},{"ar":"علم","en":"knowledge/flag","tr":"'ilm"}] },
  { "name":"Ghain", "ar":"غ", "sound":"gh (French r)", "isolated":"غ", "initial":"غـ", "medial":"ـغـ", "final":"ـغ", "type":"moon letter", "tip":"Like the French 'r' or gargling. Same shape as ع but with a dot above.", "examples":[{"ar":"غداء","en":"lunch","tr":"ghadā'"},{"ar":"غريب","en":"strange","tr":"gharīb"}] },
  { "name":"Fa", "ar":"ف", "sound":"f", "isolated":"ف", "initial":"فـ", "medial":"ـفـ", "final":"ـف", "type":"moon letter", "tip":"Like English 'f'. A small loop with ONE dot above. Compare with ق (two dots).", "examples":[{"ar":"فم","en":"mouth","tr":"fam"},{"ar":"فيل","en":"elephant","tr":"fīl"}] },
  { "name":"Qaf", "ar":"ق", "sound":"q (deep k)", "isolated":"ق", "initial":"قـ", "medial":"ـقـ", "final":"ـق", "type":"moon letter", "tip":"A deep 'k' from the back of the throat. Deeper loop than ف with TWO dots above.", "examples":[{"ar":"قلب","en":"heart","tr":"qalb"},{"ar":"قمر","en":"moon","tr":"qamar"}] },
  { "name":"Kaf", "ar":"ك", "sound":"k", "isolated":"ك", "initial":"كـ", "medial":"ـكـ", "final":"ـك", "type":"moon letter", "tip":"Like English 'k'. Has a small hamza-like mark inside.", "examples":[{"ar":"كتاب","en":"book","tr":"kitāb"},{"ar":"كلب","en":"dog","tr":"kalb"}] },
  { "name":"Lam", "ar":"ل", "sound":"l", "isolated":"ل", "initial":"لـ", "medial":"ـلـ", "final":"ـل", "type":"sun letter", "tip":"Like English 'l'. A tall elegant stroke that curves. Combined with Alif makes لا (lā).", "examples":[{"ar":"لون","en":"color","tr":"lawn"},{"ar":"ليل","en":"night","tr":"layl"}] },
  { "name":"Mim", "ar":"م", "sound":"m", "isolated":"م", "initial":"مـ", "medial":"ـمـ", "final":"ـم", "type":"moon letter", "tip":"Like English 'm'. A small circle/loop shape.", "examples":[{"ar":"ماء","en":"water","tr":"mā'"},{"ar":"مدينة","en":"city","tr":"madīna"}] },
  { "name":"Nun", "ar":"ن", "sound":"n", "isolated":"ن", "initial":"نـ", "medial":"ـنـ", "final":"ـن", "type":"sun letter", "tip":"Like English 'n'. Looks like a small boat/cup with ONE dot above.", "examples":[{"ar":"نور","en":"light","tr":"nūr"},{"ar":"نهر","en":"river","tr":"nahr"}] },
  { "name":"Ha2", "ar":"ه", "sound":"h", "isolated":"ه", "initial":"هـ", "medial":"ـهـ", "final":"ـه", "type":"moon letter", "tip":"Like English 'h'. Shape changes a lot between forms — learn each form!", "examples":[{"ar":"هواء","en":"air","tr":"hawā'"},{"ar":"هدية","en":"gift","tr":"hadiyya"}] },
  { "name":"Waw", "ar":"و", "sound":"w / ū / ō", "isolated":"و", "initial":"و", "medial":"ـو", "final":"ـو", "type":"moon letter", "tip":"Like 'w' in 'wow' or 'oo' in 'moon'. Looks like a '9' shape. Doesn't connect left.", "examples":[{"ar":"ولد","en":"boy","tr":"walad"},{"ar":"ورد","en":"rose","tr":"ward"}] },
  { "name":"Ya", "ar":"ي", "sound":"y / ī / ē", "isolated":"ي", "initial":"يـ", "medial":"ـيـ", "final":"ـي", "type":"moon letter", "tip":"Like 'y' in 'yes' or 'ee' in 'feet'. TWO dots below. Similar base to ب but dots below.", "examples":[{"ar":"يد","en":"hand","tr":"yad"},{"ar":"يوم","en":"day","tr":"yawm"}] }
]
